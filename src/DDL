CREATE TABLE `items` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `item_name` varchar(300) NOT NULL,
  `current_cnt` int(11) DEFAULT 0,
  `created_at` datetime DEFAULT current_timestamp(),
  PRIMARY KEY (id)
)


CREATE TABLE item_price (
    id INT(11) NOT NULL AUTO_INCREMENT,
    item_id INT(11) NOT NULL,
    price1 INT(11) NOT NULL,
    price2 INT(11) NOT NULL,
    price3 INT(11) NOT NULL,
    create_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (id)
);



CREATE TABLE `item_history` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `customer` varchar(300) NOT NULL,
  `customer_tel` varchar(30) NOT NULL,
  `date` varchar(30) NOT NULL,
  `item_idx` int(11) NOT NULL,
  `item_name` varchar(300) NOT NULL,
  `cnt` int(11) NOT NULL,
  `type` varchar(8) DEFAULT '0',
  `created_at` datetime DEFAULT current_timestamp(),
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=26 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci;



CREATE TABLE `wheelchair_rentals` (
  `rental_id` int(11) NOT NULL AUTO_INCREMENT,
  `wheelchair_type` varchar(50) NOT NULL,
  `start_date` varchar(20) DEFAULT NULL,
  `end_date` varchar(20) DEFAULT NULL,
  `customer_name` varchar(50) NOT NULL,
  `customer_tel` varchar(20) NOT NULL,
  `remarks` varchar(4000) DEFAULT NULL,
  `payment` varchar(10) DEFAULT NULL,
  `created_at` timestamp NULL DEFAULT current_timestamp(),
  PRIMARY KEY (`rental_id`)
) ENGINE=InnoDB AUTO_INCREMENT=18 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci;





